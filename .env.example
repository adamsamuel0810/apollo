# --- Authentication (password gate) ---
# The single shared password reviewers use to access the app.
APP_PASSWORD=change-me-strong-password

# Secret used to sign the auth session cookie (any long random string).
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=replace-with-a-long-random-secret

# --- AI orchestration ---
# Anthropic API key powering the semantic checks.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the Claude model (defaults to a fast, capable model).
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Optional: set to "0" to disable AI checks entirely (deterministic-only mode).
ENABLE_AI=1

# --- High-fidelity slide rendering (optional) ---
# ConvertAPI secret used to rasterize each slide to a pixel-identical PNG
# (PPTX -> PNG). When set, slides render as exact images with highlight
# overlays on top. When unset, the app falls back to the built-in HTML
# renderer (free + fully private, but not pixel-perfect).
# Get credentials at https://www.convertapi.com/ (free trial credits available).
# Use EITHER a token (preferred) or the legacy secret:
CONVERTAPI_TOKEN=
CONVERTAPI_SECRET=
