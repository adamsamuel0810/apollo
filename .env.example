# --- Authentication (password gate) ---
# The single shared password reviewers use to access the app.
APP_PASSWORD=change-me-strong-password

# Secret used to sign the auth session cookie (any long random string).
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=replace-with-a-long-random-secret

# --- AI orchestration ---
# Anthropic API key powering the semantic checks.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the Claude model (defaults to a fast, capable model).
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Optional: set to "0" to disable AI checks entirely (deterministic-only mode).
ENABLE_AI=1
